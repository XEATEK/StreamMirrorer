{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ProcessName": "StreamMirror",
  "Seq": {
    "ServerUrl": "http://localhost:6363",
    "ApiKey": "PASTE_YOUR_API_KEY_HERE",
    "MinLogLevel": 0,
    "MinLogServices": {
      "Microsoft": 3,
      "StreamMirrorer.Utility.HlsStreamHandler": 2,
      "StreamMirrorer.Utility.DataSavers": 1
    }
  },
  "LinkFormats": {
    "Twitch": "https://www.twitch.tv/{StreamerName}"
  },
  "FileArchiverDir": "/app/Streams",
  "StreamLink": {
    "TwitchParameters": "\"--twitch-api-header=Authorization=OAuth PASTE_YOUR_OAUTH_KEY_HERE\""
  },
  "FFMpegPath": "ffmpeg"
}